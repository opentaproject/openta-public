apiVersion: apps/v1
kind: Deployment
metadata:
  annotations:
    kompose.cmd: kompose convert
    kompose.version: 1.17.0 (a74acad)
  creationTimestamp: null
  labels:
    io.kompose.service: {{SUBPATH}}
    name: {{SUBPATH}}
  name: {{SUBPATH}}
spec:
  replicas: 1
  strategy:
    type: Recreate
  selector:
    matchLabels:
      name: {{SUBPATH}}
  template:
    metadata:
      creationTimestamp: null
      labels:
        io.kompose.service: {{SUBPATH}}
        name: {{SUBPATH}}
    spec:
      containers:
        - name: web
          args:
            - gunicorn
            - backend.wsgi:application
            - --bind
            - 0.0.0.0:8000
            - --env
            - DJANGO_SETTINGS_MODULE=backend.settings_production_docker
            - --timeout
            - "300"
          env:
          - name: WEB_CONCURRENCY
            value: "10"
          - name: OPENTA_SUBPATH
            value: "{{SUBPATH}}"
          - name: OPENTA_VERSION
            value: "{{VERSION}}"
          image: {{DOCKERREPOSITORY}}/openta:{{VERSION}}
          imagePullPolicy: Always
          volumeMounts:
          - mountPath: /srv/openta/django/backend/media
            name: site-data
            subPath: media
          - mountPath: /srv/openta/exercises
            name: site-data
            subPath: exercises
          - mountPath: /tmp
            name: tmp
          workingDir: /srv/openta/django/backend/
          resources:
            requests:
              cpu: "0.05"
              memory: "700Mi"

        - image: postgres:12-alpine
          name: db
          env:
          - name: PGDATA
            value: "/var/lib/postgresql/data/db"
          - name: POSTGRES_PASSWORD
            value: supersecret
          volumeMounts:
          - mountPath: /var/lib/postgresql/data
            name: site-data
            subPath: database
          resources:
            requests:
              cpu: "0.05"
              memory: "256Mi"

        - image: {{DOCKERREPOSITORY}}/nginx:{{VERSION}}
          imagePullPolicy: Always
          name: nginx
          command: ["/bin/sh"]
          args: ["-c", "envsubst '$OPENTA_SUBPATH $USE_SSL' < /etc/nginx/conf.d/default.template > /etc/nginx/conf.d/default.conf && exec nginx -g 'daemon off;'"]
          env:
          - name: OPENTA_SUBPATH
            value: "/{{SUBPATH}}"
          - name: USE_SSL
            value: "{{OPENTA_USE_SSL}}"
          ports:
          - containerPort: 8080
          volumeMounts:
          - mountPath: /srv/openta/django/backend/media
            name: site-data
            subPath: media
          - mountPath: /srv/openta/exercises
            name: site-data
            subPath: exercises
          resources:
            requests:
              cpu: "0.05"
              memory: "128Mi"

        - image: redis:3.2.0
          name: redis
          volumeMounts:
          - mountPath: /data
            name: site-data
            subPath: redis
          resources:
            requests:
              cpu: "0.05"
              memory: "128Mi"

        - name: rqworker
          args:
            - python
            - manage.py
            - rqworker
          image: {{DOCKERREPOSITORY}}/openta:{{VERSION}}
          imagePullPolicy: Always
          volumeMounts:
          - mountPath: /srv/openta/django/backend/media
            name: site-data
            subPath: media
          - mountPath: /tmp
            name: tmp
          workingDir: /srv/openta/django/backend/
          resources:
            requests:
              cpu: "0.05"
              memory: "128Mi"
      imagePullSecrets:
        - name: dockerkey
      restartPolicy: Always
      volumes:
      - name: site-data
        persistentVolumeClaim:
          claimName: {{SUBPATH}}-data
      - name: tmp
        emptyDir: {}

status: {}
