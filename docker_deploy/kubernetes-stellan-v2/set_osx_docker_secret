#/usr/bin/env bash
echo "Setting docker token in cluster..."
kubectl delete secret dockerkey --namespace openta
#kubectl create secret generic dockerkey --from-file=.dockerconfigjson=$HOME/.docker/config-linux.json --type=kubernetes.io/dockerconfigjson --namespace openta
kubectl create secret generic dockerkey --from-file=.dockerconfigjson=$HOME/.docker/config.json.works --type=kubernetes.io/dockerconfigjson --namespace openta
echo "Done."
