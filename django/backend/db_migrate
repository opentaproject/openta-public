#/bin/bash
export SUBDOMAIN=$1
subdomain=$1
dbnamefile="/srv/multicourse/${subdomain}/dbname.txt"
echo $dbnamefile
if test -e $dbnamefile ; then
	echo "FILE FOUND"
	dbname=`cat $dbnamefile | tr -d '\n'`
else 
	echo $dbnamefile not found so exit;
	exit
fi
echo "MIGRATE " ${subdomain}
python manage.py migrate --database=${subdomain}
sed s/DB_NAME/${dbname}/ < fixtures/course.json > /tmp/course.json
python manage.py loaddata fixtures/auth.json --database=${subdomain}
python manage.py loaddata /tmp/course.json --database=${subdomain}
python manage.py createcachetable --database=${subdomain}
