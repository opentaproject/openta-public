#/bin/bash
for i in /subdomain-data/$1
do
	subdomain=`basename $i`
	echo $subdomain
	dbnamefile="/subdomain-data/${subdomain}/dbname.txt"
	echo $dbnamefile
    	if test -e $dbnamefile ; then
    		echo "FILE FOUND"
    		dbname=`cat $dbnamefile | tr -d '\n'`
        else 
    		echo "FILINITIALIZED"
		break
	fi
	echo $subdomain $dbname
	dbfile=${i}/${dbname}.db
	if test -f ${dbfile} ; then
		echo DBFILE = $dbfile
		echo DBNAME = $dbname
		#psql -U postgres -c "DROP DATABASE $dbname;"
		#psql -U postgres -c "CREATE DATABASE $dbname OWNER postgres;"
		echo Create datbase $dbname from $dbfile
		cat $dbfile | pg_restore -U openta  -d $dbname
	else
		echo Cannot restore: $dbfile does not exist
	fi
	SUBDOMAIN=$subdomain python manage.py repair_subdomain
	SUBDOMAIN=$subdomain python manage.py reinitialize
done

