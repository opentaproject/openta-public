#/bin/bash
for i in /srv/multicourse/$1
do
	echo ${i}
	subdomain=`basename $i`
	echo $subdomain
	dbnamefile="/srv/multicourse/${subdomain}/dbname.txt"
	echo $dbnamefile
    	if test -e $dbnamefile ; then
    		echo "FILE FOUND"
    		dbname=`cat $dbnamefile | tr -d '\n'`
        else 
    		echo "FILINITIALIZED"
		break
	fi
	echo $subdomain $dbname
	pg_dump -C -Fc $dbname > /srv/multicourse/${subdomain}/${dbname}.db
done
